{
  "openapi": "3.1.0",
  "info": {
    "title": "Hermes Agent API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://action.daisanityado-co.uk"
    }
  ],
  "paths": {
    "/api/v1/runs": {
      "post": {
        "operationId": "createRun",
        "summary": "建立 Hermes 任務",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "task_name": {
                    "type": "string"
                  },
                  "priority": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "任務已建立",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "workforce_item_id": {
                      "type": "string"
                    },
                    "run_id": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "get": {
        "operationId": "listRuns",
        "summary": "列出所有任務",
        "responses": {
          "200": {
            "description": "任務列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "runs": {
                      "type": "array"
                    },
                    "count": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/runs/{run_id}/wait": {
      "get": {
        "operationId": "waitRun",
        "summary": "等待任務完成",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "任務狀態",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "run_id": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    },
                    "found_in": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/runs/{run_id}/artifacts": {
      "get": {
        "operationId": "listArtifacts",
        "summary": "列出任務產出",
        "parameters": [
          {
            "name": "run_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "產出列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "artifacts": {
                      "type": "array"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/command-center/system-status": {
      "get": {
        "operationId": "systemStatus",
        "summary": "檢查系統連線狀態",
        "responses": {
          "200": {
            "description": "系統狀態",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "connected": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
